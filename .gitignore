# Nix build output
/result
/result-*

# git-hooks.nix generated (symlink into /nix/store, regenerated per devShell)
.pre-commit-config.yaml

# Go build artifacts
/bin/
*.test
*.out

# the flake supplies deps via an offline module proxy (goModules FOD); a stray
# local `go mod vendor` dir should never be committed
/vendor/

# direnv (nix-direnv cache)
.direnv/
